<section class="section story" id="story" style="background-image: url('{{ 'decks-floor.jpg' | asset_url }}'); background-size: cover; background-position: center;">
  <div class="container">
    <div class="story-grid story-grid--inverted">
      <div class="story-media reveal d1">
        <a href="{{ section.settings.btn_url | default: '/pages/our-process' }}" class="btn story-btn-large">{{ section.settings.btn_text }}</a>
      </div>
      <div class="story-text story-text--right">
        <div class="reveal">
          <span class="eyebrow section-label" style="color:#ffffff;">{{ section.settings.eyebrow }}</span>
          <h2 class="section-heading" style="color:#ffffff;">{{ section.settings.heading }}</h2>
          <div class="gold-bar"></div>
          <p class="section-body" style="color:#ffffff;">{{ section.settings.body }}</p>
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Brand Story",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow label",
      "default": "Our Story"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Built From Boards With a Story"
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body text",
      "default": "Every ring starts with a skateboard that has already lived a life. We preserve the layered wood, color, and character of the deck, then shape it into a clean everyday ring made for people who value craft, movement, and originality."
    },
    {
      "type": "text",
      "id": "btn_text",
      "label": "Button text",
      "default": "See How We Make Them"
    },
    {
      "type": "url",
      "id": "btn_url",
      "label": "Button link"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge text",
      "default": "Boards with a Life of Their Own"
    },
    {
      "type": "text",
      "id": "badge_sub",
      "label": "Badge subtext",
      "default": "Est. Bayshore · Coastal Craft"
    }
  ],
  "presets": [
    {
      "name": "Brand Story"
    }
  ]
}
{% endschema %}
