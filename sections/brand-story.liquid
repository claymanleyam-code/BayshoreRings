<style>
  #story { padding-top: 5.75rem !important; padding-bottom: 5.75rem !important; }
  #products { padding-top: 4.4rem !important; padding-bottom: 4.4rem !important; }
  .section-slide { opacity: 0; transform: translateY(34vh) !important; transition: transform 0.85s cubic-bezier(0.22, 1, 0.36, 1), opacity 0.5s ease !important; }
  .section-slide.in { opacity: 1; transform: translateY(0) !important; }
</style>
<section class="section story" id="story">
  <div class="story-bg-img" style="background-image:url('{{ 'decks-floor.jpg' | asset_url }}');"></div>
  <div class="story-bg-overlay"></div>
  <div class="container story-container">
    <div class="story-split">
      <div class="story-split-btn reveal">
        <a href="{{ section.settings.btn_url | default: '/pages/our-process' }}" class="btn btn-gold">{{ section.settings.btn_text }}</a>
      </div>
      <div class="story-split-text reveal d1">
        <span class="eyebrow section-label">{{ section.settings.eyebrow }}</span>
        <h2 class="section-heading">{{ section.settings.heading }}</h2>
        <div class="gold-bar"></div>
        <p class="section-body">{{ section.settings.body }}</p>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Brand Story",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow label",
      "default": "Our Story"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Built From Boards With a Story"
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body text",
      "default": "Every ring starts with a skateboard that has already lived a life. We preserve the layered wood, color, and character of the deck, then shape it into a clean everyday ring made for people who value craft, movement, and originality."
    },
    {
      "type": "text",
      "id": "btn_text",
      "label": "Button text",
      "default": "See How We Make Them"
    },
    {
      "type": "url",
      "id": "btn_url",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "Brand Story"
    }
  ]
}
{% endschema %}
