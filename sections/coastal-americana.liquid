<section class="section coastal" id="coastal">
  <div class="container">
    <div class="coastal-inner reveal">
      <span class="eyebrow">{{ section.settings.eyebrow }}</span>
      <h2>{{ section.settings.heading }}</h2>
      <div class="coastal-rule"></div>
      <p>{{ section.settings.body }}</p>
      <div class="coastal-stats">
        {%- for block in section.blocks -%}
          <div {{ block.shopify_attributes }}>
            <span class="stat-num">{{ block.settings.number }}</span>
            <span class="stat-lbl">{{ block.settings.label }}</span>
          </div>
        {%- endfor -%}
      </div>
    </div>
  </div>

  <figure class="coastal-photo-wrap reveal">
    <img
      src="https://images.unsplash.com/photo-1547447134-cd3f5c716030?fm=jpg&q=80&w=1600&auto=format&fit=crop"
      alt="Skateboarder riding concrete at speed"
      class="coastal-photo"
      loading="lazy"
      width="1024"
      height="500">
  </figure>

  <figure class="coastal-photo-wrap coastal-photo-skate-wrap reveal">
    <img
      src="https://cdn.shopify.com/s/files/1/0530/0695/8744/t/22/assets/the-role-of-skateboard-clothing-in-skate-culture_550x.jpg"
      alt="Skateboarding culture and community"
      class="coastal-photo coastal-photo--skate"
      loading="lazy"
      width="1024"
      height="500">
  </figure>
</section>

{% schema %}
{
  "name": "Coastal Americana",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow label",
      "default": "The Community"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Jewelry for the Culture."
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body text",
      "default": "Skate culture doesn't follow trends — it sets them. We make jewelry that's built the same way: from reclaimed materials that waste nothing, worn by people who actually skate. Sustainable by design. Made to last as long as the passion does."
    }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Stat",
      "settings": [
        {
          "type": "text",
          "id": "number",
          "label": "Number",
          "default": "100%"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Recycled Wood"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Coastal Americana",
      "blocks": [
        {
          "type": "stat",
          "settings": { "number": "100%", "label": "Recycled Wood" }
        },
        {
          "type": "stat",
          "settings": { "number": "7", "label": "Maple Plies" }
        },
        {
          "type": "stat",
          "settings": { "number": "1", "label": "Of a Kind" }
        }
      ]
    }
  ]
}
{% endschema %}
