<section class="hero" id="home">
  <div class="hero-text">
    <div class="hero-kicker">
      <div class="hero-kicker-line"></div>
      <span>{{ section.settings.kicker }}</span>
    </div>
    <h1>{{ section.settings.heading }}</h1>
    <p class="hero-sub">{{ section.settings.subheading }}</p>
    <div class="hero-actions">
      <a href="{{ section.settings.btn_primary_url | default: '/collections/all' }}" class="btn btn-gold btn-hero-primary">{{ section.settings.btn_primary }}</a>
      <a href="{{ section.settings.btn_secondary_url | default: '/pages/our-process' }}" class="btn btn-ghost">{{ section.settings.btn_secondary }}</a>
    </div>
    <div class="hero-trust">
      <span class="trust-item">Skateboard Rings</span>
      <span class="trust-item">Recycled Jewelry</span>
      <span class="trust-item">Tampa, FL</span>
      <span class="trust-item">Wooden Jewelry</span>
    </div>
  </div>

  <div class="hero-bg">
    <img class="hero-ring-photo" src="{{ 'about-working.jpg' | asset_url }}" alt="Bayshore Rings — handcrafted rings from recycled skateboard decks" loading="eager">
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker text",
      "default": "Bayshore Rings · Small Batch · Coastal Craft"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Handcrafted Rings From Recycled Skateboards"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Bayshore Rings turns retired skateboard decks into clean, durable rings with natural color, character, and history in every piece."
    },
    {
      "type": "text",
      "id": "btn_primary",
      "label": "Primary button text",
      "default": "Shop Rings"
    },
    {
      "type": "url",
      "id": "btn_primary_url",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "btn_secondary",
      "label": "Secondary button text",
      "default": "Our Process"
    },
    {
      "type": "url",
      "id": "btn_secondary_url",
      "label": "Secondary button link"
    }
  ],
  "presets": [
    {
      "name": "Hero"
    }
  ]
}
{% endschema %}
