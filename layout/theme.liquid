<!DOCTYPE html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  {%- if template.name == 'index' -%}
    <title>Bayshore Rings | Skateboard Rings &amp; Recycled Wooden Jewelry — Tampa, FL</title>
    <meta name="description" content="Handcrafted skateboard rings &amp; recycled wooden jewelry made in Tampa, FL. Bayshore Rings turns retired skateboard decks into unique recycled jewelry — eco-friendly Tampa jewelry made in small batches.">
    <meta name="keywords" content="skateboard rings, recycled jewelry, Tampa jewelry, wooden jewelry, recycled skateboard rings, wooden wedding bands, eco-friendly rings, skateboard wedding bands, Tampa FL jewelry">

  {%- elsif template.name == 'product' -%}
    <title>{{ product.title | escape }} | Skateboard Ring &amp; Recycled Wooden Jewelry — Bayshore Rings</title>
    <meta name="description" content="{{ product.description | strip_html | truncate: 120, '' | default: '' | escape }}{% if product.description == blank %}Handcrafted skateboard ring — recycled wooden jewelry made in Tampa, FL. Each piece is unique recycled jewelry shaped from a retired skateboard deck.{% endif %}">
    <meta name="keywords" content="skateboard rings, recycled jewelry, wooden jewelry, Tampa jewelry, {{ product.title | escape | downcase }}, recycled skateboard ring, eco-friendly wooden jewelry">

  {%- elsif template.name == 'collection' -%}
    <title>{{ collection.title | escape }} | Skateboard Rings &amp; Recycled Wooden Jewelry — Bayshore Rings</title>
    <meta name="description" content="Shop {{ collection.title | escape }} — handcrafted skateboard rings &amp; recycled wooden jewelry by Bayshore Rings. Tampa-made, eco-friendly recycled jewelry from retired skateboard decks.">
    <meta name="keywords" content="skateboard rings, recycled jewelry, wooden jewelry, Tampa jewelry, recycled skateboard jewelry, wooden rings Tampa FL">

  {%- else -%}
    <title>
      {%- if page_title == shop.name -%}
        {{ shop.name }} — Handcrafted Rings From Recycled Skateboards
      {%- else -%}
        {{ page_title }} — {{ shop.name }}
      {%- endif -%}
    </title>
    <meta name="description" content="{{ page_description | default: shop.description | escape }}">
  {%- endif -%}

  <!-- Canonical -->
  <link rel="canonical" href="{{ canonical_url }}">

  <!-- Open Graph -->
  <meta property="og:site_name" content="Bayshore Rings">
  {%- if template.name == 'product' -%}
    <meta property="og:type" content="product">
    <meta property="og:title" content="{{ product.title | escape }} | Recycled Wooden Jewelry — Bayshore Rings">
    <meta property="og:description" content="Handcrafted skateboard ring &amp; recycled wooden jewelry from Tampa, FL. {{ product.description | strip_html | truncate: 140, '...' | escape }}">
    <meta property="og:image" content="{{ product.featured_image | image_url: width: 1200 }}">
    <meta property="product:price:amount" content="{{ product.price | money_without_currency }}">
    <meta property="product:price:currency" content="{{ cart.currency.iso_code }}">
  {%- elsif template.name == 'index' -%}
    <meta property="og:type" content="website">
    <meta property="og:title" content="Bayshore Rings | Skateboard Rings &amp; Recycled Wooden Jewelry — Tampa, FL">
    <meta property="og:description" content="Handcrafted skateboard rings &amp; recycled wooden jewelry made in Tampa, FL. Unique eco-friendly Tampa jewelry from retired skateboard decks — small batch, coastal craft.">
    <meta property="og:image" content="{{ 'logo-512.png' | asset_url }}">
    <meta property="og:image:width" content="512">
    <meta property="og:image:height" content="512">
  {%- else -%}
    <meta property="og:type" content="website">
    <meta property="og:title" content="{{ page_title }} — {{ shop.name }}">
    <meta property="og:description" content="{{ page_description | default: shop.description | escape }}">
  {%- endif -%}
  <meta property="og:url" content="{{ canonical_url }}">

  <!-- Favicon — multiple sizes for Google search listing & browser tabs -->
  <link rel="icon" type="image/png" sizes="96x96" href="{{ 'favicon-96.png' | asset_url }}">
  <link rel="icon" type="image/png" sizes="32x32" href="{{ 'favicon-32.png' | asset_url }}">
  <link rel="icon" type="image/png" sizes="16x16" href="{{ 'favicon-16.png' | asset_url }}">
  <link rel="apple-touch-icon" sizes="192x192" href="{{ 'logo-192.png' | asset_url }}">
  <link rel="apple-touch-icon" sizes="512x512" href="{{ 'logo-512.png' | asset_url }}">
  <meta name="msapplication-TileImage" content="{{ 'logo-192.png' | asset_url }}">

  <!-- JSON-LD Structured Data -->
  {%- if template.name == 'index' -%}
    <script type="application/ld+json">
    [
      {
        "@context": "https://schema.org",
        "@type": "Organization",
        "name": "Bayshore Rings",
        "url": "{{ shop.url }}",
        "logo": {
          "@type": "ImageObject",
          "url": "{{ 'logo-512.png' | asset_url }}",
          "width": 512,
          "height": 512
        },
        "image": "{{ 'logo-512.png' | asset_url }}",
        "description": "Tampa, Florida jewelry maker crafting unique skateboard rings and recycled wooden jewelry from retired skateboard decks. Eco-friendly Tampa jewelry — small-batch recycled jewelry made by hand.",
        "keywords": "skateboard rings, recycled jewelry, Tampa jewelry, wooden jewelry, recycled skateboard rings, eco-friendly rings, wooden wedding bands",
        "foundingLocation": {
          "@type": "Place",
          "address": {
            "@type": "PostalAddress",
            "addressLocality": "Tampa",
            "addressRegion": "FL",
            "addressCountry": "US"
          }
        },
        "contactPoint": {
          "@type": "ContactPoint",
          "email": "contact@bayshorerings.com",
          "contactType": "customer service"
        }
      },
      {
        "@context": "https://schema.org",
        "@type": "WebSite",
        "name": "Bayshore Rings",
        "url": "{{ shop.url }}",
        "potentialAction": {
          "@type": "SearchAction",
          "target": "{{ shop.url }}/search?q={search_term_string}",
          "query-input": "required name=search_term_string"
        }
      }
    ]
    </script>

  {%- elsif template.name == 'product' -%}
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Product",
      "name": {{ product.title | json }},
      "description": {{ product.description | strip_html | json }},
      "image": "{{ product.featured_image | image_url: width: 1200 }}",
      "url": "{{ shop.url }}{{ product.url }}",
      "sku": {{ product.selected_or_first_available_variant.sku | json }},
      "brand": {
        "@type": "Brand",
        "name": "Bayshore Rings"
      },
      "category": "Wooden Jewelry",
      "material": "Recycled Skateboard Wood",
      "keywords": "skateboard rings, recycled jewelry, wooden jewelry, Tampa jewelry, recycled skateboard ring, eco-friendly wooden jewelry",
      "additionalProperty": [
        { "@type": "PropertyValue", "name": "Material", "value": "Recycled Skateboard Wood" },
        { "@type": "PropertyValue", "name": "Origin", "value": "Tampa, Florida" },
        { "@type": "PropertyValue", "name": "Type", "value": "Wooden Jewelry" }
      ],
      "offers": {
        "@type": "AggregateOffer",
        "priceCurrency": "{{ cart.currency.iso_code }}",
        "lowPrice": "{{ product.price_min | money_without_currency | remove: ',' }}",
        "highPrice": "{{ product.price_max | money_without_currency | remove: ',' }}",
        "offerCount": {{ product.variants.size }},
        "availability": "{% if product.available %}https://schema.org/InStock{% else %}https://schema.org/OutOfStock{% endif %}",
        "seller": {
          "@type": "Organization",
          "name": "Bayshore Rings"
        }
      }
      {%- if product.metafields.reviews.rating != blank -%}
      ,"aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "{{ product.metafields.reviews.rating.value.rating }}",
        "ratingCount": "{{ product.metafields.reviews.rating_count }}"
      }
      {%- endif -%}
    }
    </script>
  {%- endif -%}

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Josefin+Slab:ital,wght@0,300;0,400;0,600;0,700;1,400&family=Barlow:wght@300;400;500;600&family=Barlow+Condensed:wght@500;600;700&family=Oswald:wght@400;500;600;700&display=swap" rel="stylesheet">

  {{ content_for_header }}
  {{ 'bayshore.css' | asset_url | stylesheet_tag }}
</head>
<body>

<!-- ANNOUNCEMENT BAR -->
<div class="nav-announce">Free shipping on U.S. orders · Small batch · Handmade in Tampa, FL</div>

<!-- NAV -->
<nav class="nav" id="mainNav">
  <a href="/" class="nav-brand">
    <img src="{{ 'logo.png' | asset_url }}" alt="Bayshore Rings" class="nav-logo-img">
  </a>
  <button class="hamburger" id="navToggle" aria-label="Toggle menu">
    <span></span><span></span><span></span>
  </button>
  <ul class="nav-links" id="navLinks">
    <li><a href="/">Home</a></li>
    <li><a href="/pages/our-process">Our Process</a></li>
    <li><a href="/pages/about">About</a></li>
    <li><a href="/pages/reviews">Reviews</a></li>
    <li class="nav-shop-wrap">
      <a href="/collections/all" class="nav-shop-trigger">
        Shop Rings
        <svg class="nav-chevron" width="10" height="7" viewBox="0 0 10 7" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="1 1.5 5 5.5 9 1.5"/></svg>
      </a>
      <div class="nav-shop-preview" aria-hidden="true">
        <div class="nav-shop-grid">
          {%- assign _preview = collections['all'] -%}
          {%- for product in _preview.products limit: 4 -%}
            <a href="{{ product.url }}" class="nav-shop-card" tabindex="-1">
              <div class="nav-shop-card-img">
                {%- if product.featured_image -%}
                  {{ product.featured_image | image_url: width: 280 | image_tag:
                    loading: 'lazy',
                    alt: product.featured_image.alt | default: product.title
                  }}
                {%- endif -%}
              </div>
              <div class="nav-shop-card-info">
                <span class="nav-shop-card-name">{{ product.title }}</span>
                <span class="nav-shop-card-price">{{ product.price | money }}</span>
              </div>
            </a>
          {%- endfor -%}
        </div>
        <a href="/collections/all" class="nav-shop-all" tabindex="-1">View All Rings &rarr;</a>
      </div>
    </li>
  </ul>
  <a href="/cart" class="nav-cart" aria-label="Cart, {{ cart.item_count }} item{% if cart.item_count != 1 %}s{% endif %}">
    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
    {%- if cart.item_count > 0 -%}
      <span class="nav-cart-count">{{ cart.item_count }}</span>
    {%- endif -%}
  </a>
</nav>

<main>
  {{ content_for_layout }}
</main>

<!-- FOOTER — split panel layout -->
<footer class="sf" id="contact">
  <div class="sf-split">

    <!-- LEFT: gradient + newsletter -->
    <div class="sf-left">
      <a href="/" class="sf-logo-link">
        <img src="{{ 'logo.png' | asset_url }}" alt="Bayshore Rings" class="sf-logo">
      </a>
      <h3 class="sf-nl-heading">Become a Bayshore insider.</h3>
      <p class="sf-nl-sub">First drop notifications, behind-the-scenes from the workshop, and early access to limited batches — straight to your inbox.</p>
      {%- form 'customer', id: 'SfNewsletter', class: 'sf-form' -%}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <div class="sf-email-wrap">
          <input
            type="email"
            name="contact[email]"
            class="sf-email-input"
            placeholder="Your email"
            aria-label="Email address"
            required>
          <button type="submit" class="sf-email-btn">Subscribe</button>
