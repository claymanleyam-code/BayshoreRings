<section class="section coastal" id="coastal">
  <div class="container">
    <div class="coastal-inner reveal">
      <span class="eyebrow">{{ section.settings.eyebrow }}</span>
      <h2>{{ section.settings.heading }}</h2>
      <div class="coastal-rule"></div>
      <p>{{ section.settings.body }}</p>
      <div class="coastal-stats">
        {%- for block in section.blocks -%}
          <div {{ block.shopify_attributes }}>
            <span class="stat-num">{{ block.settings.number }}</span>
            <span class="stat-lbl">{{ block.settings.label }}</span>
          </div>
        {%- endfor -%}
      </div>
    </div>
  </div>

  <figure class="coastal-photo-wrap reveal">
    <img
      src="https://images.unsplash.com/photo-1547447134-cd3f5c716030?fm=jpg&q=80&w=1600&auto=format&fit=crop"
      alt="Skateboarder riding concrete at speed"
      class="coastal-photo"
      loading="lazy"
      width="1024"
      height="500">
  </figure>

  <figure class="coastal-photo-wrap coastal-photo-skate-wrap reveal">
    <img
      src="https://images.unsplash.com/photo-1622495966027-e0173192c728?fm=jpg&q=80&w=1600&auto=format&fit=crop"
      alt="Skater mid-trick at a concrete skatepark"
      class="coastal-photo coastal-photo--skate"
      loading="lazy"
      width="1024"
      height="500">
  </figure>
</section>

{% schema %}
{
  "name": "Coastal Americana",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow label",
      "default": "Brand Direction"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Coastal Craft. Skate Roots."
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body text",
      "default": "Bayshore Rings blends small-town coastal design with the grit and creativity of skate culture. The result is a ring that feels classic, personal, and different without trying too hard."
    }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Stat",
      "settings": [
        {
          "type": "text",
          "id": "number",
          "label": "Number",
          "default": "100%"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Recycled Wood"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Coastal Americana",
      "blocks": [
        {
          "type": "stat",
          "settings": { "number": "100%", "label": "Recycled Wood" }
        },
        {
          "type": "stat",
          "settings": { "number": "7", "label": "Maple Plies" }
        },
        {
          "type": "stat",
          "settings": { "number": "1", "label": "Of a Kind" }
        }
      ]
    }
  ]
}
{% endschema %}
