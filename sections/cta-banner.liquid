<section class="cta-section">
  <div class="cta-content reveal">
    <span class="eyebrow">{{ section.settings.eyebrow }}</span>
    <h2>{{ section.settings.heading }}</h2>
    <a href="{{ section.settings.btn_url | default: '/collections/all' }}" class="btn btn-gold" style="font-size:0.85rem; padding:1rem 2.5rem;">
      {{ section.settings.btn_text }}
    </a>
  </div>
</section>

{% schema %}
{
  "name": "CTA Banner",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow label",
      "default": "Get Yours"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Wear the Board. Keep the Story."
    },
    {
      "type": "text",
      "id": "btn_text",
      "label": "Button text",
      "default": "Shop the Collection"
    },
    {
      "type": "url",
      "id": "btn_url",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "CTA Banner"
    }
  ]
}
{% endschema %}
