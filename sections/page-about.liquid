<!-- ── WHERE IT STARTED ───────────────────────────────────── -->
<section class="about-maker">
  <div class="about-maker-grid">
    <div class="about-maker-text-col">
      <h2 class="about-maker-name">Where It Started</h2>
      <p class="about-maker-bio">{{ section.settings.origin_body_1 }}</p>
      {%- if section.settings.origin_body_2 != blank -%}
        <p class="about-maker-bio">{{ section.settings.origin_body_2 }}</p>
      {%- endif -%}
    </div>
    <div class="about-maker-img-col">
      <img
        src="{{ 'about-decks.jpg' | asset_url }}"
        alt="Skateboard decks — Bayshore Rings"
        class="about-maker-photo"
        loading="eager">
    </div>
  </div>
</section>

<!-- ── MEET THE MAKER ─────────────────────────────────────── -->
<section class="about-founder">
  <div class="about-founder-grid">
    <div class="about-founder-img-col">
      <img
        src="{{ 'about-first-workshop.jpg' | asset_url }}"
        alt="Clay — founder of Bayshore Rings"
        class="about-founder-photo"
        loading="lazy">
    </div>
    <div class="about-founder-text-col">
      <span class="eyebrow about-eyebrow">{{ section.settings.founder_eyebrow }}</span>
      <h2 class="about-founder-name">{{ section.settings.founder_name }}</h2>
      <p class="about-maker-bio">{{ section.settings.founder_bio }}</p>
      {%- if section.settings.founder_bio_2 != blank -%}
        <p class="about-maker-bio">{{ section.settings.founder_bio_2 }}</p>
      {%- endif -%}
    </div>
  </div>
</section>

<style>
/* ── SHARED ── */
.about-maker,
.about-founder {
  background: #ffffff !important;
  padding: 0;
  margin: 0;
}
.about-maker {
  padding-top: 6.5rem;
}
.about-maker-grid,
.about-founder-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  min-height: 50vh;
  align-items: stretch;
}

/* ── IMAGES ── */
.about-maker-img-col,
.about-founder-img-col {
  overflow: hidden;
  padding: 0;
}
.about-maker-photo,
.about-founder-photo {
  width: 100%;
  height: 100%;
  max-width: none;
  max-height: none;
  object-fit: cover;
  object-position: center;
  display: block;
}

/* ── TEXT COLUMNS ── */
.about-maker-text-col,
.about-founder-text-col {
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 3rem 4.5rem;
  background: #ffffff !important;
}
.about-eyebrow {
  display: block;
  font-family: 'Barlow Condensed', sans-serif !important;
  font-size: 0.63rem !important;
  font-weight: 600 !important;
  letter-spacing: 0.35em !important;
  text-transform: uppercase !important;
  color: #000000 !important;
  margin-bottom: 1.25rem;
}
.about-maker-name,
.about-founder-name {
  font-family: 'Bebas Neue', sans-serif;
  font-size: clamp(3.5rem, 6vw, 6rem);
  font-weight: 400;
  color: #000000;
  line-height: 0.9;
  text-transform: uppercase;
  letter-spacing: 0.03em;
  margin-bottom: 1.75rem;
}
.about-maker-bio {
  font-family: 'Barlow', sans-serif;
  font-size: 0.92rem;
  color: rgba(0,0,0,0.65);
  line-height: 1.75;
  font-weight: 400;
  margin-bottom: 1.25rem;
  max-width: 48ch;
}

/* ── RESPONSIVE ── */
@media (max-width: 768px) {
  .about-maker-grid,
  .about-founder-grid { grid-template-columns: 1fr; min-height: auto; }
  .about-maker-img-col { order: 1; height: 55vw; }
  .about-maker-text-col { order: 2; }
  .about-founder-img-col { order: 1; height: 55vw; }
  .about-founder-text-col { order: 2; }
  .about-maker-text-col,
  .about-founder-text-col { padding: 2rem 2rem 3rem; }
}
</style>

{% schema %}
{
  "name": "About Page",
  "settings": [
    { "type": "header", "content": "Hero" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Our Story" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Built From Boards" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Every ring starts with a skateboard that already lived a life. We just give it another one." },

    { "type": "header", "content": "Origin Story" },
    { "type": "text", "id": "origin_eyebrow", "label": "Eyebrow", "default": "Where It Started" },
    { "type": "text", "id": "origin_heading", "label": "Heading", "default": "Turning My Beat Deck Into Wearable Art" },
    { "type": "textarea", "id": "origin_body_1", "label": "Paragraph 1", "default": "My broken decks started piling up and I wanted to give them new life. I started cutting them up in my dads garage, and turning them into a piece that shows everyone a symbol of my lifestyle." },
    { "type": "textarea", "id": "origin_body_2", "label": "Paragraph 2", "default": "I took my board from the skatepark to my finger, and it just felt right." },
    { "type": "text", "id": "badge_text", "label": "Badge text", "default": "One Board. One Ring. One Story." },
    { "type": "text", "id": "badge_sub", "label": "Badge subtext", "default": "Bayshore · Coastal Craft" },

    { "type": "header", "content": "The Material" },
    { "type": "text", "id": "material_eyebrow", "label": "Eyebrow", "default": "The Material" },
    { "type": "text", "id": "material_heading", "label": "Heading", "default": "Why Skateboards" },
    { "type": "textarea", "id": "material_body", "label": "Body" },

    { "type": "header", "content": "Values Section" },
    { "type": "text", "id": "values_eyebrow", "label": "Eyebrow", "default": "What We Stand For" },
    { "type": "text", "id": "values_heading", "label": "Heading", "default": "Made Right. No Shortcuts." },

    { "type": "header", "content": "Founder" },
    { "type": "image_picker", "id": "founder_image", "label": "Founder photo" },
    { "type": "text", "id": "founder_eyebrow", "label": "Eyebrow", "default": "The Maker" },
    { "type": "text", "id": "founder_name", "label": "Name", "default": "Clay" },
    { "type": "textarea", "id": "founder_bio", "label": "Bio paragraph 1" },
    { "type": "textarea", "id": "founder_bio_2", "label": "Bio paragraph 2" },
    { "type": "text", "id": "founder_signature", "label": "Signature (optional)" },

    { "type": "header", "content": "Process Teaser" },
    { "type": "text", "id": "process_eyebrow", "label": "Eyebrow", "default": "How Its Made" },
    { "type": "text", "id": "process_heading", "label": "Heading", "default": "Want to see the whole process?" },
    { "type": "textarea", "id": "process_body", "label": "Body" },
    { "type": "url", "id": "process_link", "label": "Link" },
    { "type": "text", "id": "process_btn", "label": "Button text", "default": "See How We Make Them" },

    { "type": "header", "content": "CTA Banner" },
    { "type": "text", "id": "cta_eyebrow", "label": "Eyebrow", "default": "Get Yours" },
    { "type": "text", "id": "cta_heading", "label": "Heading", "default": "Wear the Board. Keep the Story." },
    { "type": "url", "id": "cta_link", "label": "Link" },
    { "type": "text", "id": "cta_btn", "label": "Button text", "default": "Shop the Collection" }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Material Stat",
      "settings": [
        { "type": "text", "id": "number", "label": "Number", "default": "7" },
        { "type": "text", "id": "label", "label": "Label", "default": "Maple Plies" }
      ]
    },
    {
      "type": "value",
      "name": "Value Card",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "No New Materials" },
        { "type": "textarea", "id": "body", "label": "Body", "default": "Every ring is made from a board that already existed." }
      ]
    }
  ],
  "presets": [
    {
      "name": "About Page",
      "blocks": [
        { "type": "stat", "settings": { "number": "100%", "label": "Recycled Wood" } },
        { "type": "stat", "settings": { "number": "7", "label": "Maple Plies" } },
        { "type": "stat", "settings": { "number": "1", "label": "Of a Kind" } }
      ]
    }
  ]
}
{% endschema %}
