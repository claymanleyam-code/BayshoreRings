<!-- ═══════════════════════════════════════════════════
     BAYSHORE RINGS — About Us Page
     ═══════════════════════════════════════════════════ -->

<!-- ── 1. PAGE HERO ────────────────────────────────────── -->
<section class="about-hero">
  <div class="container">
    <span class="eyebrow reveal d1">{{ section.settings.eyebrow | default: 'Our Story' }}</span>
    <h1 class="reveal d2">{{ section.settings.heading | default: 'Built From Boards' }}</h1>
    <p class="about-hero-sub reveal d3">{{ section.settings.subheading | default: 'Every ring starts with a skateboard that already lived a life. We just give it another one.' }}</p>
  </div>
</section>

<!-- ── 2. ORIGIN STORY ─────────────────────────────────── -->
<section class="section story about-origin">
  <div class="container">
    <div class="story-grid">
      <div class="about-origin-text">
        <h2 class="about-origin-heading reveal d1">{{ section.settings.origin_heading | default: 'A Board, a Saw, and a Good Idea' }}</h2>
        <p class="section-body reveal d2">{{ section.settings.origin_body_1 | default: 'It started the way most things worth doing start — not with a business plan, but with a question. A retired skateboard deck was sitting in the corner of a garage, and instead of the trash, it went onto the bandsaw. What came out of that first cross-section cut stopped everything. Seven maple plies. Teal, red, and raw wood stacked like a tiny landscape. A ring was the first thing that came to mind.' }}</p>
        <p class="section-body reveal d3" style="margin-top:1.25rem;">{{ section.settings.origin_body_2 | default: "Bayshore Rings grew from that one cut. We're a small operation rooted in Tampa, Florida — shaped by Bayshore Boulevard, the Gulf Coast, and a deep respect for things made by hand. Every ring we make starts with a board that's already been somewhere." }}</p>
      </div>
      <div class="story-media reveal d2">
        <div class="about-origin-photos">
          <div class="about-origin-photo-main">
            <img
              src="{{ 'about-decks.jpg' | asset_url }}"
              alt="Skateboard decks marked with ring size templates — Bayshore Rings workshop process, Tampa, FL"
              loading="lazy" width="600" height="400">
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ── 3. THE MATERIAL ─────────────────────────────────── -->
<section class="section coastal about-material">
  <div class="container">
    <div class="coastal-inner">
      <span class="eyebrow" style="color:var(--teal);display:block;margin-bottom:0.6rem;">{{ section.settings.material_eyebrow | default: 'The Material' }}</span>
      <h2 class="reveal d1">{{ section.settings.material_heading | default: 'Why Skateboards' }}</h2>
      <div class="coastal-rule"></div>
      <p class="reveal d2">{{ section.settings.material_body | default: "A skateboard deck is seven layers of hard maple, pressed and glued under thousands of pounds of force. Between those plies are thin colored veneers — teal, red, black, natural — that vary by brand, era, and rider. When you cut across the deck, those layers become the grain of the ring. No dye. No stain. That's the actual board." }}</p>
      <div class="coastal-stats reveal d3">
        {%- for block in section.blocks -%}
          {%- if block.type == 'stat' -%}
            <div class="coastal-stat" {{ block.shopify_attributes }}>
              <span class="stat-num">{{ block.settings.number }}</span>
              <span class="stat-lbl">{{ block.settings.label }}</span>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

<!-- ── 4. VALUES ───────────────────────────────────────── -->
<section class="section features about-values">
  <div class="container">
    <div class="about-values-header reveal">
      <h2 class="about-values-heading">{{ section.settings.values_heading | default: 'Made Right. No Shortcuts.' }}</h2>
    </div>
    <div class="about-values-list">
      {%- for block in section.blocks -%}
        {%- if block.type == 'value' -%}
          <div class="about-value-item reveal" {{ block.shopify_attributes }}>
            <span class="about-value-num">0{{ forloop.index }}</span>
            <div class="about-value-content">
              <h3>{{ block.settings.title }}</h3>
              <p>{{ block.settings.body }}</p>
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

<!-- ── 4B. TAMPA SKATEPARKS ─────────────────────────────── -->
<section class="section about-skateparks">
  <div class="about-skateparks-header reveal container">
    <h2 class="about-skatepark-heading">The Parks That Built the Culture</h2>
  </div>
  <div class="skatepark-grid">

    <div class="skatepark-card reveal d1">
      <img
        src="{{ 'skatepark-of-tampa.jpg' | asset_url }}"
        alt="Skatepark of Tampa (SPoT) — the legendary Florida skate venue that shaped generations of professional skateboarders and inspired Bayshore Rings"
        class="skatepark-img"
        loading="lazy"
        width="800" height="532">
      <div class="skatepark-overlay">
        <h3 class="skatepark-name">Skatepark of Tampa</h3>
        <p class="skatepark-blurb">Founded in 1993, SPoT became one of the world's most influential parks — home to Tampa Pro and Tampa Am, where generations of pros made their names.</p>
      </div>
    </div>

    <div class="skatepark-card reveal d2">
      <img
        src="{{ 'skatepark-brobowl.jpg' | asset_url }}"
        alt="BroBowl Skatepark in Tampa, Florida — a historic concrete bowl and cornerstone of Florida's skate community"
        class="skatepark-img"
        loading="lazy"
        width="1920" height="1080">
      <div class="skatepark-overlay">
        <h3 class="skatepark-name">BroBowl Skatepark</h3>
        <p class="skatepark-blurb">A vintage concrete bowl near Lowry Park, gathering local skaters since the 1970s. Living Florida skate history.</p>
      </div>
    </div>

    <div class="skatepark-card reveal d3">
      <img
        src="{{ 'skatepark-perry-harvey.jpg' | asset_url }}"
        alt="Perry Harvey Sr. Park skatepark in downtown Tampa, Florida — a community-built space honoring Tampa's civil rights legacy"
        class="skatepark-img"
        loading="lazy"
        width="746" height="497">
      <div class="skatepark-overlay">
        <h3 class="skatepark-name">Perry Harvey Sr. Park</h3>
        <p class="skatepark-blurb">Downtown Tampa skatepark honoring civil rights leader Perry Harvey Sr. Community-built, open to all skill levels.</p>
      </div>
    </div>

  </div>
</section>

<!-- ── 5. FOUNDER ──────────────────────────────────────── -->
<section class="section about-founder">
  <div class="container">
    <div class="about-founder-grid">
      <div class="about-founder-img reveal d1">
        {%- if section.settings.founder_image != blank -%}
          {{ section.settings.founder_image | image_url: width: 600 | image_tag:
            class: 'about-founder-photo',
            alt: section.settings.founder_name | default: 'Founder',
            loading: 'lazy'
          }}
        {%- else -%}
          <div class="about-founder-photos-stack">
            <img
              src="{{ 'about-first-workshop.jpg' | asset_url }}"
              alt="Bayshore Rings founder measuring and marking skateboard wood in his first garage workshop in Tampa, FL"
              class="about-founder-photo"
              loading="lazy" width="600" height="800">
            <div class="about-founder-inset">
              <img
                src="{{ 'about-rings-hand.jpg' | asset_url }}"
                alt="Three handcrafted recycled skateboard rings — Bayshore Rings finished products"
                loading="lazy" width="300" height="400">
            </div>
          </div>
        {%- endif -%}
      </div>
      <div class="about-founder-text reveal d2">
        <span class="eyebrow">{{ section.settings.founder_eyebrow | default: 'The Maker' }}</span>
        <h2 class="about-founder-name">{{ section.settings.founder_name | default: 'Clay' }}</h2>
        <p class="section-body">{{ section.settings.founder_bio | default: "This is where your story goes. Where you grew up, how you got into skateboarding, when you made your first ring, what this brand means to you. People buy from people — especially in small-batch craft. Replace this with your real story and it'll do more work than any ad ever could." }}</p>
        <p class="section-body" style="margin-top:1rem;">{{ section.settings.founder_bio_2 | default: "Add a second paragraph here — your background, your workshop, Bayshore Boulevard, what Tampa and the Gulf Coast mean to this brand." }}</p>
        {%- if section.settings.founder_signature != blank -%}
          <p class="about-founder-sig">{{ section.settings.founder_signature }}</p>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

<!-- ── 5B. BAYSHORE BLVD PHOTO ──────────────────────────── -->
<figure class="about-bayshore-figure">
  <img
    src="{{ 'bayshore-blvd.jpg' | asset_url }}"
    alt="Sunset over Bayshore Boulevard, Tampa, Florida — the longest continuous sidewalk in the United States and the coastal backdrop of Bayshore Rings"
    class="about-bayshore-img"
    loading="lazy"
    width="1024"
    height="576">
  <figcaption class="about-bayshore-caption">Bayshore Boulevard · Tampa, FL — sunset over Hillsborough Bay.</figcaption>
</figure>

<!-- ── 6. PROCESS TEASER ───────────────────────────────── -->
<section class="section about-process-teaser">
  <div class="container">
    <div class="about-process-inner reveal d1">
      <div>
        <h2 class="about-process-heading">{{ section.settings.process_heading | default: 'Want to see the whole process?' }}</h2>
        <p class="section-body" style="margin-top:0.75rem;">{{ section.settings.process_body | default: 'From finding the right board to the final hand-sanding. Four steps, built with care every time.' }}</p>
      </div>
      <a href="{{ section.settings.process_link | default: '/pages/our-process' }}" class="btn btn-navy">
        {{ section.settings.process_btn | default: 'See How We Make Them' }} &rarr;
      </a>
    </div>
  </div>
</section>

<!-- ── 7. CTA ──────────────────────────────────────────── -->
<section class="cta-section">
  <div class="cta-content">
    <span class="eyebrow">{{ section.settings.cta_eyebrow | default: 'Get Yours' }}</span>
    <h2>{{ section.settings.cta_heading | default: 'Wear the Board. Keep the Story.' }}</h2>
    <a href="{{ section.settings.cta_link | default: '/collections/all' }}" class="btn btn-gold">
      {{ section.settings.cta_btn | default: 'Shop the Collection' }}
    </a>
  </div>
</section>

<style>
/* ── About Hero ────────────────────────────────────────── */
.about-hero {
  background: var(--navy);
  padding: 7rem 2rem 5rem;
  text-align: center;
  position: relative;
  overflow: hidden;
}
.about-hero .container { position: relative; z-index: 1; }
.about-hero h1 {
  font-family: 'Bebas Neue', sans-serif;
  font-size: clamp(4rem, 8vw, 8rem);
  font-weight: 400;
  color: var(--cream);
  letter-spacing: 0.04em;
  line-height: 0.95;
  margin: 0.75rem 0 1.5rem;
}
.about-hero-sub {
  font-size: 1.15rem;
  color: rgba(240,231,211,0.72);
  max-width: 42ch;
  margin: 0 auto;
  line-height: 1.75;
  font-weight: 300;
}

/* ── Origin story ──────────────────────────────────────── */
.about-origin-heading {
  font-family: 'Oswald', sans-serif;
  font-size: clamp(1.3rem, 2.2vw, 1.8rem);
  font-weight: 600;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  color: var(--navy);
  line-height: 1.2;
  margin-bottom: 1.25rem;
}
.about-origin .section-body,
.about-founder .section-body,
.about-process-teaser .section-body {
  font-size: 1.08rem;
  line-height: 1.82;
  color: #1a1a1a;
  font-weight: 400;
}

/* ── Origin photo ──────────────────────────────────────── */
.about-origin-photos { position: relative; width: 100%; }
.about-origin-photo-main img {
  width: 100%;
  aspect-ratio: 3 / 2;
  object-fit: cover;
  display: block;
  border-radius: 2px;
}

/* ── Values (editorial stacked list) ───────────────────── */
.about-values { background: var(--cream); }
.about-values-header { margin-bottom: 3rem; padding-bottom: 2rem; border-bottom: 1px solid rgba(0,0,0,0.07); }
.about-values-heading {
  font-family: 'Bebas Neue', sans-serif;
  font-size: clamp(2.5rem, 5vw, 4.5rem);
  letter-spacing: 0.04em;
  color: var(--navy);
  line-height: 0.95;
}
.about-values-list { display: flex; flex-direction: column; }
.about-value-item {
  display: grid;
  grid-template-columns: 72px 1fr;
  gap: 2.5rem;
  align-items: start;
  padding: 2.5rem 0;
  border-bottom: 1px solid rgba(0,0,0,0.07);
}
.about-value-num {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 2.8rem;
  color: rgba(0,0,0,0.07);
  line-height: 1;
  letter-spacing: 0.04em;
  padding-top: 0.15rem;
  flex-shrink: 0;
}
.about-value-content h3 {
  font-family: 'Oswald', sans-serif;
  font-size: 1rem;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--navy);
  margin-bottom: 0.6rem;
}
.about-value-content p {
  font-size: 1rem;
  line-height: 1.82;
  color: #1a1a1a;
}

/* ── Skateparks heading ────────────────────────────────── */
.about-skateparks-header { margin-bottom: 2rem; }
.about-skatepark-heading {
  font-family: 'Bebas Neue', sans-serif;
  font-size: clamp(2.5rem, 5vw, 4.5rem);
  letter-spacing: 0.04em;
  color: var(--navy);
  line-height: 0.95;
}
.skatepark-blurb {
  font-size: 1rem;
  line-height: 1.65;
  color: rgba(240,231,211,0.88);
  font-weight: 400;
}

/* ── Founder ───────────────────────────────────────────── */
.about-founder { background: var(--cream-light); }
.about-founder-grid {
  display: grid;
  grid-template-columns: 1fr 1.5fr;
  gap: 5rem;
  align-items: center;
}
.about-founder-img { position: relative; }
.about-founder-photo {
  width: 100%;
  aspect-ratio: 3/4;
  object-fit: cover;
  border-radius: 2px;
  display: block;
}
.about-founder-name {
  font-family: 'Bebas Neue', sans-serif;
  font-size: clamp(2.5rem, 4vw, 4rem);
  letter-spacing: 0.04em;
  color: var(--navy);
  line-height: 0.95;
  margin: 0.5rem 0 1.25rem;
}
.about-founder-photos-stack { position: relative; }
.about-founder-photos-stack .about-founder-photo {
  width: 100%;
  aspect-ratio: 3 / 4;
  object-fit: cover;
  object-position: center top;
  display: block;
  border-radius: 2px;
}
.about-founder-inset {
  position: absolute;
  bottom: -1.5rem;
  right: -1.5rem;
  width: 52%;
  border: 3px solid var(--cream-light);
  border-radius: 2px;
  overflow: hidden;
  box-shadow: 0 8px 30px rgba(0,0,0,0.2);
}
.about-founder-inset img {
  width: 100%;
  aspect-ratio: 3 / 4;
  object-fit: cover;
  display: block;
}
.about-founder-sig {
  font-family: 'Josefin Slab', serif;
  font-size: 1.6rem;
  font-style: italic;
  color: var(--navy);
  margin-top: 1.5rem;
  opacity: 0.75;
}

/* ── Process teaser ────────────────────────────────────── */
.about-process-teaser { background: var(--cream); border-top: 1px solid rgba(0,0,0,0.07); }
.about-process-heading {
  font-family: 'Oswald', sans-serif;
  font-size: clamp(1.2rem, 2vw, 1.6rem);
  font-weight: 600;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  color: var(--navy);
  line-height: 1.2;
}
.about-process-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 3rem;
  flex-wrap: wrap;
}

/* ── Responsive ────────────────────────────────────────── */
@media (max-width: 860px) {
  .about-founder-grid { grid-template-columns: 1fr; gap: 3rem; }
  .about-founder-img { max-width: 360px; margin: 0 auto; }
  .about-founder-inset { display: none; }
  .about-process-inner { flex-direction: column; align-items: flex-start; gap: 1.5rem; }
  .about-value-item { grid-template-columns: 52px 1fr; gap: 1.5rem; }
}
@media (max-width: 600px) {
  .about-hero { padding: 5rem 2rem 4rem; }
}
</style>

{% schema %}
{
  "name": "About Page",
  "settings": [
    { "type": "header", "content": "Hero" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Our Story" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Built From Boards" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Every ring starts with a skateboard that already lived a life. We just give it another one." },

    { "type": "header", "content": "Origin Story" },
    { "type": "text", "id": "origin_eyebrow", "label": "Eyebrow", "default": "Where It Started" },
    { "type": "text", "id": "origin_heading", "label": "Heading", "default": "When a Skateboarder Begins to Love Woodworking" },
    { "type": "textarea", "id": "origin_body_1", "label": "Paragraph 1", "default": "It started in my dad's garage. Broken skateboards were piling up — boards that had been skated hard, snapped, and had nowhere left to go. Instead of tossing them, I started cutting them up to make things. Jewelry first. Whatever I could figure out." },
    { "type": "textarea", "id": "origin_body_2", "label": "Paragraph 2", "default": "Rings ended up being the thing. Something about the cross-section of a deck — seven layers of hard maple with teal, red, and raw wood running through it — just looked right on a finger. Bayshore Rings grew from there. Still small, still made by hand, still started from boards that already had a life." },
    { "type": "text", "id": "badge_text", "label": "Badge text", "default": "One Board. One Ring. One Story." },
    { "type": "text", "id": "badge_sub", "label": "Badge subtext", "default": "Bayshore · Coastal Craft" },

    { "type": "header", "content": "The Material" },
    { "type": "text", "id": "material_eyebrow", "label": "Eyebrow", "default": "The Material" },
    { "type": "text", "id": "material_heading", "label": "Heading", "default": "Why Skateboards" },
    { "type": "textarea", "id": "material_body", "label": "Body" },

    { "type": "header", "content": "Values Section" },
    { "type": "text", "id": "values_eyebrow", "label": "Eyebrow", "default": "What We Stand For" },
    { "type": "text", "id": "values_heading", "label": "Heading", "default": "Made Right. No Shortcuts." },

    { "type": "header", "content": "Founder" },
    { "type": "image_picker", "id": "founder_image", "label": "Founder photo" },
    { "type": "text", "id": "founder_eyebrow", "label": "Eyebrow", "default": "The Maker" },
    { "type": "text", "id": "founder_name", "label": "Name", "default": "Your Name Here" },
    { "type": "textarea", "id": "founder_bio", "label": "Bio paragraph 1" },
    { "type": "textarea", "id": "founder_bio_2", "label": "Bio paragraph 2" },
    { "type": "text", "id": "founder_signature", "label": "Signature (optional)" },

    { "type": "header", "content": "Process Teaser" },
    { "type": "text", "id": "process_eyebrow", "label": "Eyebrow", "default": "How Its Made" },
    { "type": "text", "id": "process_heading", "label": "Heading", "default": "Want to see the whole process?" },
    { "type": "textarea", "id": "process_body", "label": "Body" },
    { "type": "url", "id": "process_link", "label": "Link" },
    { "type": "text", "id": "process_btn", "label": "Button text", "default": "See How We Make Them" },

    { "type": "header", "content": "CTA Banner" },
    { "type": "text", "id": "cta_eyebrow", "label": "Eyebrow", "default": "Get Yours" },
    { "type": "text", "id": "cta_heading", "label": "Heading", "default": "Wear the Board. Keep the Story." },
    { "type": "url", "id": "cta_link", "label": "Link" },
    { "type": "text", "id": "cta_btn", "label": "Button text", "default": "Shop the Collection" }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Material Stat",
      "settings": [
        { "type": "text", "id": "number", "label": "Number", "default": "7" },
        { "type": "text", "id": "label", "label": "Label", "default": "Maple Plies" }
      ]
    },
    {
      "type": "value",
      "name": "Value Card",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "No New Materials" },
        { "type": "textarea", "id": "body", "label": "Body", "default": "Every ring is made from a board that already existed. We don't source new wood. We reclaim what's already there." }
      ]
    }
  ],
  "presets": [
    {
      "name": "About Page",
      "blocks": [
        { "type": "stat", "settings": { "number": "100%", "label": "Recycled Wood" } },
        { "type": "stat", "settings": { "number": "7", "label": "Maple Plies" } },
        { "type": "stat", "settings": { "number": "1", "label": "Of a Kind" } },
        { "type": "value", "settings": { "title": "No New Materials", "body": "Every ring is made from a board that already existed. We don't source new wood. We reclaim what's already there." } },
        { "type": "value", "settings": { "title": "Small Batch Always", "body": "We don't run production lines. Rings are made in small batches, by hand, with attention to every one." } },
        { "type": "value", "settings": { "title": "Coastal Craft", "body": "Rooted in Tampa, Florida — shaped by Bayshore Boulevard, the Gulf Coast, and the kind of making that takes time to get right." } }
      ]
    }
  ]
}
{% endschema %}
