<!-- ═══════════════════════════════════════════════════
     BAYSHORE RINGS — Our Process Page
     ═══════════════════════════════════════════════════ -->

<!-- ── HERO ────────────────────────────────────────────── -->
<div
  class="proc-hero"
  style="background-image:url('https://images.unsplash.com/photo-1554635917-1fb8f0f63f7c?fm=jpg&q=80&w=1600&auto=format&fit=crop')">
  <div class="proc-hero-overlay" aria-hidden="true"></div>
  <div class="container">
    <span class="eyebrow reveal d1" style="color:#ffffff;">Handcrafted</span>
    <h1 class="reveal d2">From Retired Deck<br>to Daily Wear</h1>
    <p class="proc-hero-sub reveal d3">Built without compromise. Every ring starts with reclaimed maple — a material skaters already trust with their feet. No new lumber. No synthetic finishes. Just something built to last.</p>
  </div>
</div>

<!-- ── WHERE EVERY BOARD COMES FROM ────────────────────── -->
<section class="section proc-intro">
  <div class="container">
    <div class="proc-intro-grid">
      <div class="reveal d1">
        <h2 class="proc-intro-heading">Where the Wood Comes From</h2>
        <p class="section-body">Every ring starts with reclaimed hard maple — the same wood skate decks are built from for a reason. Dense, durable, and naturally beautiful, hard maple is one of the most resilient hardwoods available. We use it exclusively.</p>
        <p class="section-body" style="margin-top:1rem;">By working with reclaimed wood, we eliminate the need for newly harvested lumber and keep usable material out of the waste stream. Every ring is a direct investment in a more sustainable approach to jewelry that doesn't compromise on quality.</p>
      </div>
      <div class="proc-community-visual reveal d2">
        <div class="proc-stat-stack">
          <div class="proc-stat-item">
            <span class="proc-stat-num">100%</span>
            <span class="proc-stat-label">Reclaimed Wood</span>
          </div>
          <div class="proc-stat-item">
            <span class="proc-stat-num">0</span>
            <span class="proc-stat-label">New Wood Used</span>
          </div>
          <div class="proc-stat-item">
            <span class="proc-stat-num">1 of 1</span>
            <span class="proc-stat-label">Every Ring Is Unique</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ── PROCESS IMAGE GRID ───────────────────────────────── -->
<section class="section proc-gallery">
  <div class="container">
    <div class="proc-gallery-grid">
      <div class="proc-gallery-item proc-gallery-item--large">
        <img
          src="https://www.skatedeluxe.com/blog/wp-content/uploads/2016/10/Skateboard-Deck-Plys-Close-Up.jpg"
          alt="Close-up cross-section of a skateboard deck showing seven maple plies"
          class="proc-gallery-img"
          loading="lazy" width="800" height="560">
        <span class="proc-gallery-label">The Source Material</span>
      </div>
      <div class="proc-gallery-item">
        <img
          src="https://everskate.com/wp-content/uploads/2020/02/skateboard-art-1.jpg"
          alt="Colorful skateboard deck art — the raw character we preserve in every ring"
          class="proc-gallery-img"
          loading="lazy" width="600" height="420">
        <span class="proc-gallery-label">Ridden Hard</span>
      </div>
      <div class="proc-gallery-item">
        <img
          src="https://images.unsplash.com/photo-1763392199096-6efd9d28d8cc?fm=jpg&q=80&w=1200&auto=format&fit=crop"
          alt="Close-up of warm maple wood grain — the layered texture of reclaimed skateboard wood"
          class="proc-gallery-img"
          loading="lazy" width="600" height="420">
        <span class="proc-gallery-label">The Grain</span>
      </div>
    </div>
  </div>
</section>

<!-- ── THE 4 STEPS ─────────────────────────────────────── -->
<section class="section proc-steps-section">
  <div class="container">
    <div class="proc-steps-header reveal">
      <h2 class="proc-steps-heading">Four Steps.<br>Zero Shortcuts.</h2>
    </div>

    <!-- STEP 01 -->
    <div class="proc-step reveal">
      <div class="proc-step-num">01</div>
      <div class="proc-step-content">
        <h3>Starting With Reclaimed Wood</h3>
        <p>We build exclusively from reclaimed skateboard wood — hard maple that's already done its job on the streets and parks. Rather than cutting down new trees, we work with material that already exists, giving it a second life as something durable, beautiful, and wearable.</p>
        <p>Hard maple is one of the strongest, most sustainable hardwoods available. The same properties that make it ideal for skating — density, grain structure, natural resilience — make it ideal for jewelry that lasts decades, not seasons.</p>
      </div>
    </div>

    <!-- STEP 02 -->
    <div class="proc-step reveal">
      <div class="proc-step-num">02</div>
      <div class="proc-step-content">
        <h3>Milling Down &amp; Prepping the Wood</h3>
        <p>Once a deck comes in, we inspect it and figure out what it's got. Then we mill it down to its cross-section — exposing the seven plies of hard maple and the colored veneers between them. This is the moment the ring's color pattern shows itself for the first time.</p>
        <p>No two boards mill out the same way. The grip tape history, the ply colors, the brand — all of it is part of what we're working with. We prep blanks from the best sections of each deck and set them aside until they're ready to shape.</p>
      </div>
    </div>

    <!-- STEP 03 -->
    <div class="proc-step reveal">
      <div class="proc-step-num">03</div>
      <div class="proc-step-content">
        <h3>Cutting, Shaping &amp; All the Finishing</h3>
        <p>The blank gets drilled, cut to width, and shaped on a precision lathe. We run through multiple rounds of sanding — starting coarse to get the form right, working down through finer and finer grits until the surface feels like nothing at all.</p>
        <p>The inside edge gets rounded and polished so it sits comfortably on the finger. The outside gets its final profile — clean and wearable. This is the stage where most of the time goes. There's no rushing a good ring.</p>
      </div>
    </div>

    <!-- STEP 04 -->
    <div class="proc-step reveal">
      <div class="proc-step-num">04</div>
      <div class="proc-step-content">
        <h3>Finished With Howard Feed-N-Wax</h3>
        <p>Every ring is hand-finished with <strong>Howard Feed-N-Wax Wood Polish &amp; Conditioner</strong> — a natural, oil-based beeswax formula. No synthetic lacquers. No UV resins. No chemical coatings that will crack or peel over time.</p>
        <p>Unlike surface sealers, Feed-N-Wax penetrates deep into the maple grain and nourishes it from the inside out. The finish feels like wood, not plastic — and only gets better the longer you wear it.</p>
        <div class="proc-feedwax-note">
          <span class="proc-feedwax-note-label">What's in it</span>
          <ul class="proc-feedwax-list">
            <li><strong>Natural beeswax</strong> — seals wood against moisture without masking feel or grain</li>
            <li><strong>Orange oil</strong> — conditions the maple plies and deepens every layer's color</li>
            <li><strong>No petroleum distillates</strong> — food-safe, trusted on fine furniture and kitchenware</li>
            <li><strong>Renewable &amp; biodegradable</strong> — aligned with a no-waste approach to materials</li>
          </ul>
        </div>
      </div>
    </div>

  </div>
</section>

<!-- ── DONATE CTA ──────────────────────────────────────── -->
<section class="section proc-donate">
  <div class="container">
    <div class="proc-donate-inner reveal">
      <div>
        <h2 class="proc-donate-heading">Built to Last.<br>Not to Replace.</h2>
        <p class="section-body">Fast fashion has a cost. We make rings from reclaimed maple and finish them with natural beeswax — no synthetic resins, no coatings that crack or peel. One ring, built right, built to stay on your finger for years.</p>
      </div>
      <div class="proc-donate-actions">
        <a href="/collections/all" class="btn btn-gold">Shop the Rings &rarr;</a>
      </div>
    </div>
  </div>
</section>

<!-- ── FINAL CTA ───────────────────────────────────────── -->
<section class="cta-section">
  <div class="cta-content reveal">
    <span class="eyebrow">Handcrafted</span>
    <h2>Every Ring Has a Story.<br>What's Yours?</h2>
    <a href="/collections/all" class="btn btn-gold" style="font-size:0.85rem;padding:1rem 2.5rem;">Shop the Collection</a>
  </div>
</section>

<style>
/* ── Process hero ──────────────────────────────────────── */
.proc-hero {
  position: relative;
  background-size: cover;
  background-position: center;
  min-height: 70vh;
  display: flex;
  align-items: center;
  text-align: center;
  overflow: hidden;
  padding: 8rem 2rem 6rem;
}
.proc-hero-overlay {
  position: absolute;
  inset: 0;
  background: rgba(8,16,32,0.72);
}
.proc-hero .container { position: relative; z-index: 1; }
.proc-hero h1 {
  font-family: 'Bebas Neue', sans-serif;
  font-size: clamp(3.5rem, 7vw, 7rem);
  font-weight: 400;
  color: #ffffff;
  letter-spacing: 0.04em;
  line-height: 0.95;
  margin: 0.75rem 0 1.5rem;
}
.proc-hero-sub {
  font-size: 1.05rem;
  color: #ffffff;
  max-width: 52ch;
  margin: 0 auto;
  line-height: 1.8;
  font-weight: 300;
}

/* ── Intro section ─────────────────────────────────────── */
.proc-intro { background: var(--cream-light); }
.proc-intro-heading {
  font-family: 'Oswald', sans-serif;
  font-size: clamp(1.3rem, 2.2vw, 1.8rem);
  font-weight: 600;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  color: var(--navy);
  line-height: 1.2;
  margin-bottom: 1.25rem;
}
.proc-intro .section-body {
  font-size: 1rem;
  line-height: 1.82;
  color: #1a1a1a;
}
.proc-intro-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 5rem;
  align-items: center;
}
.proc-community-visual { display: flex; justify-content: center; }
.proc-stat-stack {
  display: flex;
  flex-direction: column;
  width: 100%;
  max-width: 300px;
}
.proc-stat-item {
  padding: 1.4rem 0;
  border-bottom: 1px solid rgba(0,0,0,0.08);
}
.proc-stat-item:first-child { border-top: 1px solid rgba(0,0,0,0.08); }
.proc-stat-num {
  display: block;
  font-family: 'Bebas Neue', sans-serif;
  font-size: 3rem;
  color: var(--navy);
  line-height: 1;
  letter-spacing: 0.04em;
  margin-bottom: 0.2rem;
}
.proc-stat-label {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 0.65rem;
  font-weight: 600;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--muted);
}

/* ── Gallery ───────────────────────────────────────────── */
.proc-gallery { background: var(--cream); padding-top: 0; }
.proc-gallery-grid {
  display: grid;
  grid-template-columns: 1.4fr 1fr;
  grid-template-rows: 1fr 1fr;
  gap: 1rem;
}
.proc-gallery-item { position: relative; overflow: hidden; }
.proc-gallery-item--large { grid-row: span 2; }
.proc-gallery-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.5s ease;
  min-height: 200px;
}
.proc-gallery-item:hover .proc-gallery-img { transform: scale(1.04); }
.proc-gallery-label {
  position: absolute;
  bottom: 0.75rem;
  left: 0.75rem;
  font-family: 'Oswald', sans-serif;
  font-size: 0.6rem;
  font-weight: 700;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: rgba(240,231,211,0.9);
  background: rgba(0,0,0,0.45);
  padding: 0.3rem 0.6rem;
  backdrop-filter: blur(4px);
}

/* ── Steps ─────────────────────────────────────────────── */
.proc-steps-section { background: var(--cream); }
.proc-steps-header {
  margin-bottom: 4rem;
  padding-bottom: 2rem;
  border-bottom: 1px solid rgba(0,0,0,0.07);
}
.proc-steps-heading {
  font-family: 'Bebas Neue', sans-serif;
  font-size: clamp(3rem, 6vw, 5.5rem);
  letter-spacing: 0.04em;
  color: var(--navy);
  line-height: 0.95;
}
.proc-step {
  display: grid;
  grid-template-columns: 100px 1fr;
  gap: 3rem;
  align-items: start;
  padding: 3.5rem 0;
  border-bottom: 1px solid rgba(0,0,0,0.07);
}
.proc-step-num {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 4.5rem;
  font-weight: 400;
  color: rgba(0,0,0,0.07);
  line-height: 1;
  text-align: right;
  padding-top: 0.15rem;
  transition: color 0.25s;
  letter-spacing: 0.04em;
  flex-shrink: 0;
}
.proc-step:hover .proc-step-num { color: rgba(0,0,0,0.14); }
.proc-step-content h3 {
  font-family: 'Oswald', sans-serif;
  font-size: clamp(1.05rem, 1.6vw, 1.3rem);
  font-weight: 600;
  color: var(--navy);
  margin: 0 0 0.9rem;
  letter-spacing: 0.06em;
  text-transform: uppercase;
}
.proc-step-content p {
  font-size: 0.96rem;
  color: var(--muted);
  line-height: 1.82;
  margin-bottom: 0.75rem;
}
.proc-step-content p:last-of-type { margin-bottom: 0; }
.proc-inline-link {
  color: var(--teal);
  font-weight: 600;
  border-bottom: 1px solid rgba(46,126,114,0.3);
  transition: border-color 0.15s;
}
.proc-inline-link:hover { border-color: var(--teal); }

/* ── Feed-N-Wax note ───────────────────────────────────── */
.proc-feedwax-note {
  border-top: 1px solid rgba(0,0,0,0.08);
  padding-top: 1.4rem;
  margin-top: 1.6rem;
}
.proc-feedwax-note-label {
  font-family: 'Oswald', sans-serif;
  font-size: 0.58rem;
  font-weight: 700;
  letter-spacing: 0.24em;
  text-transform: uppercase;
  color: var(--teal);
  display: block;
  margin-bottom: 0.75rem;
}
.proc-feedwax-list {
  list-style: none;
  padding: 0;
  display: flex;
  flex-direction: column;
  gap: 0.45rem;
}
.proc-feedwax-list li {
  font-family: 'Barlow', sans-serif;
  font-size: 0.88rem;
  color: var(--muted);
  line-height: 1.6;
  padding-left: 1.25rem;
  position: relative;
}
.proc-feedwax-list li::before {
  content: '—';
  position: absolute;
  left: 0;
  color: var(--teal);
  font-weight: 300;
}

/* ── Donate CTA ────────────────────────────────────────── */
.proc-donate { background: var(--cream-light); }
.proc-donate-heading {
  font-family: 'Bebas Neue', sans-serif;
  font-size: clamp(2.5rem, 4vw, 4rem);
  letter-spacing: 0.04em;
  color: var(--navy);
  line-height: 0.95;
  margin-bottom: 1rem;
}
.proc-donate .section-body {
  font-size: 1rem;
  line-height: 1.75;
  color: var(--muted);
  max-width: 44ch;
}
.proc-donate-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 3rem;
  flex-wrap: wrap;
  padding: 4rem 0;
  border-top: 1px solid rgba(0,0,0,0.07);
  border-bottom: 1px solid rgba(0,0,0,0.07);
}
.proc-donate-actions { display: flex; flex-direction: column; gap: 0.75rem; flex-shrink: 0; }

/* ── Responsive ────────────────────────────────────────── */
@media (max-width: 860px) {
  .proc-intro-grid { grid-template-columns: 1fr; gap: 3rem; }
  .proc-stat-stack { max-width: 100%; flex-direction: row; flex-wrap: wrap; }
  .proc-stat-item { flex: 1; min-width: 130px; }
  .proc-gallery-grid { grid-template-columns: 1fr 1fr; grid-template-rows: auto; }
  .proc-gallery-item--large { grid-row: auto; }
  .proc-donate-inner { flex-direction: column; align-items: flex-start; }
  .proc-donate-actions { flex-direction: row; }
}
@media (max-width: 620px) {
  .proc-step { grid-template-columns: 52px 1fr; gap: 1.25rem; }
  .proc-step-num { font-size: 2.8rem; }
  .proc-gallery-grid { grid-template-columns: 1fr; }
  .proc-donate-actions { flex-direction: column; }
}
</style>

