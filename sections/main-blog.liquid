<!-- ═══════════════════════════════════════════════════
     BAYSHORE RINGS — Blog Index
     Route: /blogs/journal
     ═══════════════════════════════════════════════════ -->

{%- paginate blog.articles by 9 -%}

<!-- HERO -->
<section class="about-hero blog-hero" aria-labelledby="blog-h1">
  <div class="container">
    <span class="eyebrow reveal d1">From the Workshop</span>
    <div class="gold-bar center reveal d1" aria-hidden="true"></div>
    <h1 id="blog-h1" class="reveal d2">{{ blog.title }}</h1>
    <p class="about-hero-sub reveal d3">Stories from the workshop floor — recycled skateboard rings, Tampa skate culture, eco friendly jewelry, and the craft behind every handmade wooden ring we make.</p>
  </div>
</section>

<!-- ARTICLES GRID -->
<section class="section blog-grid-section" aria-label="Articles about Bayshore Rings skateboard jewelry">
  <div class="container">
    {%- if blog.articles_count > 0 -%}
      <div class="blog-grid">
        {%- for article in blog.articles -%}
          <article
            class="blog-card reveal"
            style="--delay:{{ forloop.index | times: 80 }}ms"
            aria-label="{{ article.title }}">
            <a href="{{ article.url }}" class="blog-card-link">

              <div class="blog-card-img-wrap{% unless article.image %} blog-card-img--placeholder{% endunless %}">
                {%- if article.image -%}
                  <img
                    src="{{ article.image | image_url: width: 800 }}"
                    alt="{{ article.image.alt | default: article.title | append: ' — Bayshore Rings handmade skateboard jewelry' | escape }}"
                    class="blog-card-img"
                    loading="lazy"
                    width="800"
                    height="500">
                {%- else -%}
                  <div class="blog-card-placeholder-inner" aria-hidden="true">
                    <svg viewBox="0 0 60 16" fill="none" aria-hidden="true">
                      <text x="0" y="13" font-family="sans-serif" font-size="11" font-weight="700" letter-spacing="4" fill="rgba(212,150,56,0.45)" text-transform="uppercase">FROM THE WORKSHOP</text>
                    </svg>
                  </div>
                {%- endif -%}
              </div>

              <div class="blog-card-body">
                <div class="blog-card-meta">
                  <time datetime="{{ article.published_at | date: '%Y-%m-%d' }}" class="blog-card-date">
                    {{ article.published_at | date: '%B %d, %Y' }}
                  </time>
                  {%- if article.tags.size > 0 -%}
                    <span class="blog-card-tag">{{ article.tags.first }}</span>
                  {%- endif -%}
                </div>
                <h2 class="blog-card-title">{{ article.title }}</h2>
                <p class="blog-card-excerpt">
                  {%- if article.excerpt != blank -%}
                    {{ article.excerpt | strip_html | truncate: 160 }}
                  {%- else -%}
                    {{ article.content | strip_html | truncate: 160 }}
                  {%- endif -%}
                </p>
                <span class="blog-card-read-more" aria-hidden="true">Read Article →</span>
              </div>

            </a>
          </article>
        {%- endfor -%}
      </div>

      {%- if paginate.pages > 1 -%}
        <div class="blog-pagination" aria-label="Pagination">
          {{ paginate | default_pagination }}
        </div>
      {%- endif -%}

    {%- else -%}
      <p style="text-align:center;padding:4rem 0;color:var(--muted);">No articles published yet.</p>
    {%- endif -%}
  </div>
</section>

{%- endpaginate -%}

<!-- INTERNAL LINKS -->
<section class="section blog-links-section" aria-label="Explore Bayshore Rings">
  <div class="container">
    <div class="blog-links-row">
      <a href="/collections/all" class="blog-link-pill reveal d1">Shop Recycled Skateboard Rings</a>
      <a href="/pages/our-process" class="blog-link-pill reveal d2">How Each Ring Is Made</a>
      <a href="/pages/about" class="blog-link-pill reveal d3">About Us</a>
      <a href="/pages/reviews" class="blog-link-pill reveal d4">Customer Reviews</a>
    </div>
  </div>
</section>

<style>
/* ── Blog Hero ── */
.blog-hero { padding-bottom: 3rem; }

/* ── Article Grid ── */
.blog-grid-section { background: var(--cream-light); }
.blog-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.75rem;
}
.blog-card {
  background: #fff;
  border: 1px solid var(--cream-dark);
  border-radius: 10px;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  transition: box-shadow 0.25s, transform 0.25s;
}
.blog-card:hover {
  box-shadow: 0 8px 32px rgba(26,40,71,0.1);
  transform: translateY(-3px);
}
.blog-card-link { display: flex; flex-direction: column; height: 100%; color: inherit; }
.blog-card-link:focus-visible { outline: 2px solid var(--gold); outline-offset: 2px; }

.blog-card-img-wrap {
  width: 100%;
  aspect-ratio: 16 / 10;
  overflow: hidden;
  background: var(--navy);
  flex-shrink: 0;
}
.blog-card-img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 0.4s ease; }
.blog-card:hover .blog-card-img { transform: scale(1.04); }
.blog-card-img--placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, var(--navy-dark) 0%, var(--navy) 100%);
}
.blog-card-placeholder-inner { opacity: 0.6; }

.blog-card-body {
  padding: 1.5rem 1.75rem 1.75rem;
  display: flex;
  flex-direction: column;
  gap: 0.65rem;
  flex: 1;
}
.blog-card-meta { display: flex; align-items: center; gap: 0.75rem; flex-wrap: wrap; }
.blog-card-date {
  font-family: 'Barlow', sans-serif;
  font-size: 0.8rem;
  color: #aaa;
  font-weight: 500;
}
.blog-card-tag {
  font-family: 'Oswald', sans-serif;
  font-size: 0.62rem;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--teal);
  background: rgba(46,126,114,0.08);
  padding: 0.18rem 0.55rem;
  border-radius: 3px;
}
.blog-card-title {
  font-family: 'Oswald', sans-serif;
  font-size: 1.13rem;
  font-weight: 600;
  color: var(--navy);
  line-height: 1.25;
  letter-spacing: 0.01em;
  margin: 0;
}
.blog-card-excerpt {
  font-family: 'Barlow', sans-serif;
  font-size: 0.9rem;
  line-height: 1.65;
  color: #666;
  margin: 0;
  flex: 1;
}
.blog-card-read-more {
  font-family: 'Oswald', sans-serif;
  font-size: 0.75rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--gold);
  margin-top: 0.25rem;
  transition: letter-spacing 0.2s;
}
.blog-card:hover .blog-card-read-more { letter-spacing: 0.18em; }

.blog-pagination { text-align: center; margin-top: 3rem; }

/* ── Internal Links Strip ── */
.blog-links-section { background: var(--cream); padding: 2.5rem 2rem; }
.blog-links-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 1rem;
  flex-wrap: wrap;
}
.blog-link-pill {
  font-family: 'Oswald', sans-serif;
  font-size: 0.75rem;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--navy);
  border: 1.5px solid var(--cream-dark);
  border-radius: 20px;
  padding: 0.5rem 1.4rem;
  transition: border-color 0.2s, color 0.2s;
  white-space: nowrap;
}
.blog-link-pill:hover { border-color: var(--gold); color: var(--gold); }

@media (max-width: 900px) { .blog-grid { grid-template-columns: repeat(2, 1fr); } }
@media (max-width: 560px) { .blog-grid { grid-template-columns: 1fr; } }
</style>

{% schema %}
{
  "name": "Blog Index",
  "settings": [],
  "presets": [{ "name": "Blog Index" }]
}
{% endschema %}
