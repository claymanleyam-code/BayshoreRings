<!-- ═══════════════════════════════════════════════════
     BAYSHORE RINGS — About Us Page
     ═══════════════════════════════════════════════════ -->

<!-- ── 1. HERO ──────────────────────────────────────────── -->
<section class="about-hero" style="background-image:url('https://images.unsplash.com/photo-1499676988064-a3779763470e?fm=jpg&q=80&w=2400&auto=format&fit=crop')">
  <div class="about-hero-overlay" aria-hidden="true"></div>
  <div class="container">
    <span class="eyebrow reveal d1" style="color:var(--gold);">{{ section.settings.eyebrow | default: 'Our Story' }}</span>
    <h1 class="reveal d2">{{ section.settings.heading | default: 'Built From Boards' }}</h1>
    <p class="about-hero-sub reveal d3">{{ section.settings.subheading | default: 'Every ring starts with a skateboard that already lived a life. We just give it another one.' }}</p>
  </div>
</section>

<!-- ── 2. THE STATEMENT ──────────────────────────────────── -->
<section class="about-statement">
  <div class="container">
    <div class="reveal">
      <p class="about-statement-text">Your board carried you.<br>Now it carries something else.</p>
      <div class="about-statement-rule" aria-hidden="true"></div>
      <p class="about-statement-sub">Every ring starts as a board that was actually skated — pressed maple, worn rails, real history. We don't use new wood. We don't need to. The material is already out there.</p>
    </div>
  </div>
</section>

<!-- ── 3. ORIGIN STORY ───────────────────────────────────── -->
<section class="section story about-origin">
  <div class="container">
    <div class="story-grid">
      <div class="about-origin-text">
        <span class="eyebrow reveal d1" style="color:var(--teal);">{{ section.settings.origin_eyebrow | default: 'Where It Started' }}</span>
        <h2 class="about-origin-heading reveal d2">{{ section.settings.origin_heading | default: 'A Board, a Saw, and a Good Idea' }}</h2>
        <p class="section-body reveal d3">{{ section.settings.origin_body_1 | default: 'It started in a garage. A retired deck — cracked tail, worn rails, no more juice left in it — went onto the bandsaw instead of the trash. The cross-section stopped everything. Seven layers of hard maple with teal, red, and raw wood stacked like a tiny landscape. A ring was the obvious next move.' }}</p>
        <p class="section-body reveal d4" style="margin-top:1.25rem;">{{ section.settings.origin_body_2 | default: "Bayshore Rings grew from that one cut. Small operation, made by hand, started from boards that have already been somewhere. The goal was never to make precious jewelry. It was to make something that means something to the person wearing it — and to the rider who skated the deck it came from." }}</p>
      </div>
      <div class="story-media reveal d2">
        <div class="about-origin-photos">
          <div class="about-origin-photo-main">
            <img
              src="https://images.unsplash.com/photo-1696168406444-63be038c86ef?fm=jpg&q=80&w=1200&auto=format&fit=crop"
              alt="Skateboarder riding on cement"
              loading="lazy" width="600" height="400">
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ── 4. THE MATERIAL ───────────────────────────────────── -->
<section class="section coastal about-material">
  <div class="container">
    <div class="coastal-inner">
      <span class="eyebrow" style="color:var(--teal);display:block;margin-bottom:0.6rem;">{{ section.settings.material_eyebrow | default: 'The Material' }}</span>
      <h2 class="reveal d1">{{ section.settings.material_heading | default: 'Why Skateboards' }}</h2>
      <div class="coastal-rule"></div>
      <p class="reveal d2">{{ section.settings.material_body | default: "A skateboard deck is seven layers of hard maple, pressed and glued under thousands of pounds of force. Between those plies are thin colored veneers — teal, red, black, natural — that vary by brand, era, and rider. When you cut across the deck, those layers become the grain of the ring. No dye. No stain. That's the actual board." }}</p>
      <div class="coastal-stats reveal d3">
        {%- for block in section.blocks -%}
          {%- if block.type == 'stat' -%}
            <div class="coastal-stat" {{ block.shopify_attributes }}>
              <span class="stat-num">{{ block.settings.number }}</span>
              <span class="stat-lbl">{{ block.settings.label }}</span>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

<!-- ── 5. BUILT FOR RIDERS ───────────────────────────────── -->
<section class="section about-riders">
  <div class="container">
    <div class="about-riders-grid">
      <div class="about-riders-img reveal d1">
        <img
          src="https://images.unsplash.com/photo-1753354006417-951f5ee236e3?fm=jpg&q=80&w=1200&auto=format&fit=crop"
          alt="Skateboarder riding a concrete bowl"
          loading="lazy" width="800" height="1067">
      </div>
      <div class="reveal d2">
        <span class="eyebrow" style="color:var(--teal);">For the Rider</span>
        <h2 class="about-riders-heading">These Aren't for People Who Think Skating Is Cool.</h2>
        <p class="section-body">They're for people who actually do it. Who know what a proper pop sounds like. Who've had the same deck for three years because the concave is perfect. Who understand that a board doesn't die — it just changes shape.</p>
        <p class="section-body" style="margin-top:1rem;">We made rings for skaters because we are skaters. Every ring comes from a board that was actually ridden — not salvaged from a shelf, not bought new. Sourced from riders. Made for riders.</p>
        <a href="/collections/all" class="btn btn-navy" style="margin-top:2rem;display:inline-block;">Shop the Rings &rarr;</a>
      </div>
    </div>
  </div>
</section>

<!-- ── 6. VALUES ─────────────────────────────────────────── -->
<section class="section features about-values">
  <div class="container">
    <div class="about-values-header reveal">
      <h2 class="about-values-heading">{{ section.settings.values_heading | default: 'Made Right. No Shortcuts.' }}</h2>
    </div>
    <div class="about-values-list">
      {%- for block in section.blocks -%}
        {%- if block.type == 'value' -%}
          <div class="about-value-item reveal" {{ block.shopify_attributes }}>
            <span class="about-value-num">0{{ forloop.index }}</span>
            <div class="about-value-content">
              <h3>{{ block.settings.title }}</h3>
              <p>{{ block.settings.body }}</p>
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

<!-- ── 7. FULL-BLEED IMAGE MOMENT ────────────────────────── -->
<div
  class="about-fullbleed"
  style="background-image:url('https://images.unsplash.com/photo-1580634240125-b9f6ff4283d1?fm=jpg&q=80&w=2400&auto=format&fit=crop')"
  role="img"
  aria-label="Skateboard on concrete road">
  <div class="about-fullbleed-overlay" aria-hidden="true"></div>
  <div class="about-fullbleed-text reveal">
    <span class="about-fullbleed-eyebrow">Zero Waste</span>
    <p class="about-fullbleed-statement">No virgin wood.<br>No landfill.<br>Just a board that already existed,<br>shaped into something that lasts.</p>
  </div>
</div>

<!-- ── 8. FOUNDER ────────────────────────────────────────── -->
<section class="section about-founder">
  <div class="container">
    <div class="about-founder-grid">
      <div class="about-founder-img reveal d1">
        {%- if section.settings.founder_image != blank -%}
          {{ section.settings.founder_image | image_url: width: 600 | image_tag:
            class: 'about-founder-photo',
            alt: section.settings.founder_name | default: 'Founder',
            loading: 'lazy'
          }}
        {%- else -%}
          <div class="about-founder-photos-stack">
            <img
              src="{{ 'about-first-workshop.jpg' | asset_url }}"
              alt="Bayshore Rings founder at work in the workshop"
              class="about-founder-photo"
              loading="lazy" width="600" height="800">
            <div class="about-founder-inset">
              <img
                src="{{ 'about-rings-hand.jpg' | asset_url }}"
                alt="Handcrafted recycled skateboard rings"
                loading="lazy" width="300" height="400">
            </div>
          </div>
        {%- endif -%}
      </div>
      <div class="about-founder-text reveal d2">
        <span class="eyebrow">{{ section.settings.founder_eyebrow | default: 'The Maker' }}</span>
        <h2 class="about-founder-name">{{ section.settings.founder_name | default: 'Clay' }}</h2>
        <p class="section-body">{{ section.settings.founder_bio | default: "Replace this with your real story. Where you grew up, how you started skating, when you made your first ring, what this means to you. People buy from people — especially when the thing is made by hand." }}</p>
        <p class="section-body" style="margin-top:1rem;">{{ section.settings.founder_bio_2 | default: "Add a second paragraph here — your background, your workshop, what skateboarding means to this brand." }}</p>
        {%- if section.settings.founder_signature != blank -%}
          <p class="about-founder-sig">{{ section.settings.founder_signature }}</p>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

<!-- ── 9. FULL-BLEED SKATE IMAGE ───────────────────────── -->
<figure class="about-bayshore-figure">
  <img
    src="https://images.unsplash.com/photo-1760773766821-a3fea86fd44a?fm=jpg&q=80&w=2400&auto=format&fit=crop"
    alt="Skateboarder at a concrete skatepark"
    class="about-bayshore-img"
    loading="lazy"
    width="1024"
    height="576">
</figure>

<!-- ── 10. PROCESS TEASER ────────────────────────────────── -->
<section class="section about-process-teaser">
  <div class="container">
    <div class="about-process-inner reveal d1">
      <div>
        <h2 class="about-process-heading">{{ section.settings.process_heading | default: 'Want to see the whole process?' }}</h2>
        <p class="section-body" style="margin-top:0.75rem;">{{ section.settings.process_body | default: 'From sourcing the board to the final coat. Four steps, no shortcuts.' }}</p>
      </div>
      <a href="{{ section.settings.process_link | default: '/pages/our-process' }}" class="btn btn-navy">
        {{ section.settings.process_btn | default: 'See How We Make Them' }} &rarr;
      </a>
    </div>
  </div>
</section>

<!-- ── 11. CTA ───────────────────────────────────────────── -->
<section class="cta-section">
  <div class="cta-content">
    <span class="eyebrow">{{ section.settings.cta_eyebrow | default: 'Get Yours' }}</span>
    <h2>{{ section.settings.cta_heading | default: 'Wear the Board. Keep the Story.' }}</h2>
    <a href="{{ section.settings.cta_link | default: '/collections/all' }}" class="btn btn-gold">
      {{ section.settings.cta_btn | default: 'Shop the Collection' }}
    </a>
  </div>
</section>

<style>
/* ── About Hero ────────────────────────────────────────── */
.about-hero {
  position: relative;
  background-size: cover;
  background-position: center top;
  min-height: 80vh;
  display: flex;
  align-items: center;
  text-align: center;
  padding: 10rem 2rem 7rem;
  overflow: hidden;
}
.about-hero-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to bottom, rgba(8,16,32,0.6) 0%, rgba(8,16,32,0.78) 100%);
}
.about-hero .container { position: relative; z-index: 1; }
.about-hero h1 {
  font-family: 'Bebas Neue', sans-serif;
  font-size: clamp(4.5rem, 10vw, 9rem);
  font-weight: 400;
  color: var(--cream);
  letter-spacing: 0.04em;
  line-height: 0.9;
  margin: 0.75rem 0 1.5rem;
}
.about-hero-sub {
  font-size: 1.1rem;
  color: rgba(240,231,211,0.75);
  max-width: 44ch;
  margin: 0 auto;
  line-height: 1.8;
  font-weight: 300;
}

/* ── Statement ─────────────────────────────────────────── */
.about-statement {
  background: var(--navy);
  padding: 7rem 2rem;
}
.about-statement-text {
  font-family: 'Bebas Neue', sans-serif;
  font-size: clamp(3rem, 7vw, 6.5rem);
  color: var(--cream);
  line-height: 0.92;
  letter-spacing: 0.04em;
  max-width: 14ch;
  margin: 0;
}
.about-statement-rule {
  width: 48px;
  height: 2px;
  background: var(--gold);
  margin: 2.5rem 0;
}
.about-statement-sub {
  font-family: 'Barlow', sans-serif;
  font-size: 1.05rem;
  color: rgba(240,231,211,0.6);
  max-width: 50ch;
  line-height: 1.82;
  margin: 0;
}

/* ── Origin ────────────────────────────────────────────── */
.about-origin { background: var(--cream-light); }
.about-origin-heading {
  font-family: 'Oswald', sans-serif;
  font-size: clamp(1.3rem, 2.2vw, 1.8rem);
  font-weight: 600;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  color: var(--navy);
  line-height: 1.2;
  margin-bottom: 1.25rem;
}
.about-origin-photo-main img {
  width: 100%;
  aspect-ratio: 3 / 2;
  object-fit: cover;
  display: block;
  border-radius: 2px;
}
.about-origin .section-body {
  font-size: 1.05rem;
  line-height: 1.82;
  color: #1a1a1a;
}

/* ── Built for Riders ──────────────────────────────────── */
.about-riders { background: var(--cream); }
.about-riders-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 5rem;
  align-items: center;
}
.about-riders-img img {
  width: 100%;
  aspect-ratio: 3 / 4;
  object-fit: cover;
  object-position: center top;
  display: block;
}
.about-riders-heading {
  font-family: 'Bebas Neue', sans-serif;
  font-size: clamp(2rem, 4vw, 3.5rem);
  color: var(--navy);
  letter-spacing: 0.04em;
  line-height: 0.95;
  margin: 0.5rem 0 1.25rem;
}
.about-riders .section-body {
  font-size: 1rem;
  line-height: 1.82;
  color: #1a1a1a;
}

/* ── Values ────────────────────────────────────────────── */
.about-values { background: var(--cream-light); }
.about-values-header {
  margin-bottom: 3rem;
  padding-bottom: 2rem;
  border-bottom: 1px solid rgba(0,0,0,0.07);
}
.about-values-heading {
  font-family: 'Bebas Neue', sans-serif;
  font-size: clamp(2.5rem, 5vw, 4.5rem);
  letter-spacing: 0.04em;
  color: var(--navy);
  line-height: 0.95;
}
.about-values-list { display: flex; flex-direction: column; }
.about-value-item {
  display: grid;
  grid-template-columns: 72px 1fr;
  gap: 2.5rem;
  align-items: start;
  padding: 2.5rem 0;
  border-bottom: 1px solid rgba(0,0,0,0.07);
}
.about-value-num {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 2.8rem;
  color: rgba(0,0,0,0.07);
  line-height: 1;
  letter-spacing: 0.04em;
  padding-top: 0.15rem;
  flex-shrink: 0;
}
.about-value-content h3 {
  font-family: 'Oswald', sans-serif;
  font-size: 1rem;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--navy);
  margin-bottom: 0.6rem;
}
.about-value-content p {
  font-size: 1rem;
  line-height: 1.82;
  color: #1a1a1a;
}

/* ── Full-bleed photo ──────────────────────────────────── */
.about-fullbleed {
  position: relative;
  height: 60vh;
  min-height: 400px;
  background-size: cover;
  background-position: center;
  background-attachment: fixed;
  display: flex;
  align-items: flex-end;
}
.about-fullbleed-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(0,0,0,0.82) 0%, rgba(0,0,0,0.2) 55%, transparent 100%);
}
.about-fullbleed-text {
  position: relative;
  z-index: 1;
  padding: 3rem 2rem;
  max-width: 1200px;
  margin: 0 auto;
  width: 100%;
}
.about-fullbleed-eyebrow {
  font-family: 'Oswald', sans-serif;
  font-size: 0.6rem;
  font-weight: 700;
  letter-spacing: 0.24em;
  text-transform: uppercase;
  color: var(--gold);
  display: block;
  margin-bottom: 0.75rem;
}
.about-fullbleed-statement {
  font-family: 'Bebas Neue', sans-serif;
  font-size: clamp(2rem, 5vw, 4rem);
  color: var(--cream);
  letter-spacing: 0.04em;
  line-height: 0.95;
  max-width: 700px;
  margin: 0;
}

/* ── Founder ───────────────────────────────────────────── */
.about-founder { background: var(--cream-light); }
.about-founder-grid {
  display: grid;
  grid-template-columns: 1fr 1.5fr;
  gap: 5rem;
  align-items: center;
}
.about-founder-img { position: relative; }
.about-founder-name {
  font-family: 'Bebas Neue', sans-serif;
  font-size: clamp(2.5rem, 4vw, 4rem);
  letter-spacing: 0.04em;
  color: var(--navy);
  line-height: 0.95;
  margin: 0.5rem 0 1.25rem;
}
.about-founder-photos-stack { position: relative; }
.about-founder-photos-stack .about-founder-photo {
  width: 100%;
  aspect-ratio: 3 / 4;
  object-fit: cover;
  object-position: center top;
  display: block;
  border-radius: 2px;
}
.about-founder-inset {
  position: absolute;
  bottom: -1.5rem;
  right: -1.5rem;
  width: 52%;
  border: 3px solid var(--cream-light);
  overflow: hidden;
  box-shadow: 0 8px 30px rgba(0,0,0,0.2);
}
.about-founder-inset img {
  width: 100%;
  aspect-ratio: 3 / 4;
  object-fit: cover;
  display: block;
}
.about-founder-photo {
  width: 100%;
  aspect-ratio: 3/4;
  object-fit: cover;
  border-radius: 2px;
  display: block;
}
.about-founder .section-body {
  font-size: 1.05rem;
  line-height: 1.82;
  color: #1a1a1a;
}
.about-founder-sig {
  font-family: 'Josefin Slab', serif;
  font-size: 1.6rem;
  font-style: italic;
  color: var(--navy);
  margin-top: 1.5rem;
  opacity: 0.75;
}

/* ── Process teaser ────────────────────────────────────── */
.about-process-teaser { background: var(--cream); border-top: 1px solid rgba(0,0,0,0.07); }
.about-process-heading {
  font-family: 'Oswald', sans-serif;
  font-size: clamp(1.2rem, 2vw, 1.6rem);
  font-weight: 600;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  color: var(--navy);
  line-height: 1.2;
}
.about-process-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 3rem;
  flex-wrap: wrap;
}
.about-process-teaser .section-body {
  font-size: 1rem;
  line-height: 1.75;
  color: var(--muted);
}

/* ── Responsive ────────────────────────────────────────── */
@media (max-width: 860px) {
  .about-riders-grid { grid-template-columns: 1fr; gap: 3rem; }
  .about-riders-img { max-width: 480px; }
  .about-founder-grid { grid-template-columns: 1fr; gap: 3rem; }
  .about-founder-img { max-width: 360px; margin: 0 auto; }
  .about-founder-inset { display: none; }
  .about-value-item { grid-template-columns: 52px 1fr; gap: 1.5rem; }
  .about-process-inner { flex-direction: column; align-items: flex-start; gap: 1.5rem; }
}
@media (max-width: 768px) {
  .about-fullbleed { background-attachment: scroll; }
}
@media (max-width: 600px) {
  .about-hero { padding: 7rem 2rem 5rem; min-height: 60vh; }
  .about-statement { padding: 5rem 2rem; }
}
</style>

